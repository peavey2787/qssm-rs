{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QSSM Template Lab",
  "version": "0.1.0",
  "identifier": "com.qssm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QSSM Template Lab",
        "width": 1280,
        "height": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
